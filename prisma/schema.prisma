generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Interview / multi-tenant ───────────────────────────────────────────────

model Company {
  id                         String             @id @default(cuid())
  slug                       String             @unique
  inviteToken                String             @unique
  name                       String
  category                   String?
  industry                   String?
  description                String?
  aiContext                  String?
  interviewDurationMinutes   Int                @default(15)
  phase1DurationMinutes      Int                @default(8)
  phase2DurationMinutes      Int                @default(7)
  phase2Enabled              Boolean            @default(true)
  phase1Title                String             @default("AI Discovery")
  phase2Title                String             @default("Domain Questions")
  contactName                String?
  contactEmail               String?
  contactPhone               String?
  location                   String?
  isActive                   Boolean            @default(true)
  allowEmployeeSelfRegistration Boolean         @default(true)
  requireMobileOtpForEmployeeLogin Boolean     @default(true)
  allowedEmailDomains        String?
  registrationMode           String             @default("OPEN")
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  sessions                   InterviewSession[]
  employees                  Employee[]
  otpVerifications           OtpVerification[]
  otpAuditLogs               EmployeeOtpAuditLog[]
  campaigns                  InterviewCampaign[]
  questionBank               QuestionBank[]
  adminUsers                 AdminUser[]
  adminAuditLogs             AdminAuditLog[]
  dataExportLogs             DataExportLog[]
  reindexJobs                KnowledgeReindexJob[]
  fixedPhaseQuestions        FixedPhaseQuestion[]

  @@index([isActive])
  @@index([category])
  @@index([inviteToken])
}

// ─── Admin RBAC & audit ───────────────────────────────────────────────────────

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  role         String          @default("COMPANY_ADMIN")
  companyId    String?
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  company      Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  auditLogs    AdminAuditLog[]

  @@index([companyId])
  @@index([role])
  @@index([isActive])
}

model AdminAuditLog {
  id           String     @id @default(cuid())
  adminUserId  String?
  actorEmail   String?
  action       String
  resourceType String?
  resourceId   String?
  companyId    String?
  ipAddress    String?
  userAgent    String?
  metadata     String?
  createdAt    DateTime   @default(now())
  adminUser    AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([action])
  @@index([createdAt])
  @@index([adminUserId])
}

model DataExportLog {
  id          String   @id @default(cuid())
  companyId   String
  exportType  String
  format      String
  filter      String?
  recordCount Int      @default(0)
  fileName    String?
  actorEmail  String?
  adminUserId String?
  status      String   @default("completed")
  metadata    String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([exportType])
  @@index([createdAt])
}

model KnowledgeReindexJob {
  id              String    @id @default(cuid())
  companyId       String
  scope           String    @default("all")
  status          String    @default("pending")
  referenceCount  Int?
  experienceCount Int?
  errorMessage    String?
  actorEmail      String?
  adminUserId     String?
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model InterviewSession {
  id                String              @id @default(cuid())
  companyId         String
  employeeId        String?
  status            String              @default("active")
  language          String              @default("en")
  stakeholderType   String?
  currentSection    String              @default("A")
  introStep         Int                 @default(1)
  questionIndex     Int                 @default(0)
  completionPct     Int                 @default(0)
  consentAcceptedAt DateTime?
  consentVersion    String?
  deviceType        String?
  clientUserAgent   String?
  campaignId              String?
  campaignQuestionIndex   Int                 @default(0)
  interviewPhase          String              @default("phase1_ai")
  phase2QuestionIndex     Int                 @default(0)
  phase1StartedAt         DateTime?
  phase2StartedAt         DateTime?
  startedAt         DateTime            @default(now())
  completedAt       DateTime?
  updatedAt         DateTime            @updatedAt
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee?           @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  campaign        InterviewCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  participant     ParticipantProfile?
  messages        Message[]
  attachments     MessageAttachment[]
  processes       ProcessRecord[]
  painPoints      PainPoint[]
  requirements    Requirement[]
  integrations    IntegrationReq[]
  reporting       ReportingReq[]
  approvals       ApprovalWorkflow[]
  report          InterviewReport?
  answers         InterviewAnswer[]

  @@index([status])
  @@index([companyId])
  @@index([employeeId])
  @@index([campaignId])
  @@index([interviewPhase])
}

// ─── Phase 2 fixed objective questions (admin-controlled) ─────────────────

model FixedPhaseQuestion {
  id              String   @id @default(cuid())
  companyId       String
  sortOrder       Int
  promptEn        String   @db.Text
  promptLocale    String?  @db.Text
  interactionJson String?
  questionType    String   @default("text")
  optionsJson     String?
  section         String?
  isActive        Boolean  @default(true)
  sourceFile      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, sortOrder])
  @@index([companyId])
  @@index([companyId, isActive])
}

// ─── Campaigns & question bank ──────────────────────────────────────────────

model InterviewCampaign {
  id          String             @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      String             @default("active")
  inviteToken String?            @unique
  startsAt    DateTime?
  expiresAt   DateTime?
  isDefault   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  questions   CampaignQuestion[]
  sessions    InterviewSession[]

  @@index([companyId])
  @@index([companyId, isDefault])
  @@index([status])
}

model QuestionBank {
  id        String             @id @default(cuid())
  companyId String
  title     String
  section   String?
  category  String?
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versions  QuestionVersion[]
  campaigns CampaignQuestion[]

  @@index([companyId])
  @@index([companyId, isActive])
}

model QuestionVersion {
  id              String             @id @default(cuid())
  questionBankId  String
  version         Int                @default(1)
  promptEn        String
  promptLocale    String?
  interactionJson String?
  section         String?
  isCurrent       Boolean            @default(true)
  createdAt       DateTime           @default(now())
  questionBank    QuestionBank       @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  campaignLinks   CampaignQuestion[]

  @@unique([questionBankId, version])
  @@index([questionBankId, isCurrent])
}

model CampaignQuestion {
  id                String            @id @default(cuid())
  campaignId        String
  questionBankId    String
  questionVersionId String
  sortOrder         Int
  section           String?
  campaign          InterviewCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  questionBank      QuestionBank      @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  questionVersion   QuestionVersion   @relation(fields: [questionVersionId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sortOrder])
  @@index([campaignId])
}

model Employee {
  id                  String              @id @default(cuid())
  employeeCode        String
  companyId           String
  employeeName        String
  mobileNumber        String
  email               String?
  username            String
  passwordHash        String
  designation         String?
  department          String?
  mobileVerifiedAt    DateTime?
  isFirstLogin        Boolean             @default(true)
  accountStatus       String              @default("ACTIVE")
  failedLoginAttempts Int                 @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sessions            InterviewSession[]
  authLogs            EmployeeAuthLog[]
  otpVerifications    OtpVerification[]

  @@unique([companyId, mobileNumber])
  @@unique([companyId, email])
  @@unique([companyId, username])
  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([mobileNumber])
}

model EmployeeAuthLog {
  id         String   @id @default(cuid())
  employeeId String
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([action])
  @@index([createdAt])
}

model EmployeeOtp {
  id        String   @id @default(cuid())
  companyId String
  email     String
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([companyId, email, purpose])
  @@index([expiresAt])
}

model OtpVerification {
  id                  String    @id @default(cuid())
  companyId           String
  employeeId          String?
  purpose             String
  mobileNumber        String
  mobileNumberHash    String
  otpHash             String
  registrationPayload String?
  expiresAt           DateTime
  attempts            Int       @default(0)
  consumedAt          DateTime?
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  company             Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([companyId, purpose, mobileNumberHash])
  @@index([companyId, employeeId, purpose])
  @@index([expiresAt])
  @@index([consumedAt])
}

model EmployeeOtpAuditLog {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String?
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([action])
  @@index([createdAt])
}

model ParticipantProfile {
  id               String           @id @default(cuid())
  sessionId        String           @unique
  fullName         String?
  employeeId       String?
  department       String?
  team             String?
  designation      String?
  reportingManager String?
  location         String?
  mobile           String?
  email            String?
  contactInfo      String?
  businessContext  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  session          InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Message {
  id            String              @id @default(cuid())
  sessionId     String
  role          String
  content       String
  contentLocale String?
  metadata      String?
  section       String?
  createdAt     DateTime            @default(now())
  session       InterviewSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attachments   MessageAttachment[]
  answer        InterviewAnswer?

  @@index([sessionId])
}

model InterviewAnswer {
  id                 String           @id @default(cuid())
  sessionId          String
  messageId          String?          @unique
  assistantMsgId     String?
  interactionType    String
  rawText            String
  rawTextLocale      String?
  structuredJson     String?
  section            String?
  qualityScore       Float?
  confidenceScore    Float?
  reviewStatus       String           @default("PENDING")
  duplicateOfId      String?
  contradictionFlags String?
  reviewNotes        String?
  reviewedAt         DateTime?
  refinedAt          DateTime?
  createdAt          DateTime         @default(now())
  session            InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message            Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([interactionType])
  @@index([reviewStatus])
  @@index([confidenceScore])
}

model MessageAttachment {
  id            String           @id @default(cuid())
  sessionId     String
  messageId     String?
  fileName      String
  fileType      String
  fileSize      Int
  filePath      String
  storageKey    String?
  extractedText String?
  createdAt     DateTime         @default(now())
  session       InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message       Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([messageId])
}

model ProcessRecord {
  id             String           @id @default(cuid())
  sessionId      String
  processName    String
  objective      String?
  triggerEvent   String?
  steps          String?
  processOwner   String?
  inputs         String?
  outputs        String?
  approvalLevels String?
  escalationPath String?
  exceptions     String?
  toolsUsed      String?
  frequency      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  session        InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model PainPoint {
  id          String           @id @default(cuid())
  sessionId   String
  title       String
  description String?
  category    String?
  frequency   String?
  impact      String?
  severity    String           @default("medium")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([severity])
}

model Requirement {
  id          String           @id @default(cuid())
  sessionId   String
  type        String
  title       String
  description String?
  priority    String           @default("medium")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([type])
}

model IntegrationReq {
  id         String           @id @default(cuid())
  sessionId  String
  systemName String
  purpose    String?
  dataFlow   String?
  frequency  String?
  direction  String?
  security   String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  session    InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ReportingReq {
  id           String           @id @default(cuid())
  sessionId    String
  reportName   String
  kpis         String?
  frequency    String?
  recipients   String?
  exportFormat String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  session      InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ApprovalWorkflow {
  id          String           @id @default(cuid())
  sessionId   String
  processName String?
  levels      String
  hierarchy   String?
  sla         String?
  delegation  String?
  escalation  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model InterviewReport {
  id                   String           @id @default(cuid())
  sessionId            String           @unique
  executiveSummary     String
  processDocumentation String
  requirements         String
  painPointsSummary    String
  integrationSummary   String
  reportingSummary     String
  risks                String
  recommendations      String
  architecture         String
  actionItems          String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  session              InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── Reference data (per company) ───────────────────────────────────────────

model DataFile {
  id          String        @id @default(cuid())
  companySlug String?
  fileName    String
  fileType    String
  category    String
  fileSize    Int
  sheetCount  Int           @default(0)
  rowCount    Int           @default(0)
  description String?
  importedAt  DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  records     DataRecord[]
  sheets      DataSheet[]
  insights    DataInsight[]

  @@index([category])
  @@index([fileName])
  @@index([companySlug])
}

model DataSheet {
  id        String       @id @default(cuid())
  fileId    String
  sheetName String
  rowCount  Int          @default(0)
  colCount  Int          @default(0)
  headers   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  file      DataFile     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  records   DataRecord[]

  @@index([fileId])
}

model DataRecord {
  id        String     @id @default(cuid())
  fileId    String
  sheetId   String?
  rowIndex  Int
  category  String
  data      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  file      DataFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sheet     DataSheet? @relation(fields: [sheetId], references: [id], onDelete: SetNull)

  @@index([fileId])
  @@index([category])
  @@index([sheetId])
}

model FurnaceSpec {
  id            String   @id @default(cuid())
  companySlug   String?
  furnaceNumber String
  parameter     String
  value         String
  unit          String?
  sourceFile    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([furnaceNumber])
  @@index([companySlug])
}

model DataInsight {
  id        String    @id @default(cuid())
  fileId    String?
  category  String
  title     String
  content   String
  priority  String    @default("medium")
  tags      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  file      DataFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([fileId])
}

model PdfDocument {
  id          String   @id @default(cuid())
  companySlug String?
  fileName    String
  pageCount   Int
  content     String
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companySlug])
}

// ─── Indexed knowledge (RAG corpus) ─────────────────────────────────────────

model KnowledgeChunk {
  id            String    @id @default(cuid())
  companySlug   String
  sourceType    String
  sourceKind    String
  sourceId      String?
  sourceLabel   String
  content       String    @db.Text
  charCount     Int       @default(0)
  contentHash   String?
  metadata      String?
  reviewStatus  String?
  topicCategory String?
  reviewNotes   String?   @db.Text
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companySlug])
  @@index([companySlug, sourceType])
  @@index([companySlug, reviewStatus])
  @@index([companySlug, topicCategory])
  @@index([sourceKind])
  @@index([contentHash])
}

model RateLimitBucket {
  id          String    @id @default(cuid())
  bucketKey   String    @unique
  hitCount    Int       @default(0)
  windowStart DateTime  @default(now())
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([bucketKey])
}
