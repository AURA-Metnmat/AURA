# AURA-METNMAT — Supabase + Vercel (copy values into Vercel Environment Variables)

# Supabase Postgres — replace [YOUR-PASSWORD] with Database password (Settings → Database)
# Transaction pooler (port 6543) — app runtime
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler (port 5432) — Prisma db push / migrations
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# OpenAI
OPENAI_API_KEY=

# Anthropic Claude — primary AI for interviews, reports, knowledge retrieval
ANTHROPIC_API_KEY=

# Optional model overrides
# AI_CLAUDE_INTERVIEW_MODEL=claude-sonnet-4-20250514
# AI_CLAUDE_RETRIEVAL_MODEL=claude-3-5-haiku-latest
# AI_CLAUDE_REPORT_MODEL=claude-sonnet-4-20250514
# AI_OPENAI_MODEL=gpt-4o-mini

# Public app URL — use your Vercel production domain
NEXT_PUBLIC_APP_URL=https://aura-blond-one.vercel.app

# Set to true only for bootstrap; disable in production after creating AdminUser accounts
# ALLOW_LEGACY_ADMIN_PASSWORD=false

# Admin login (min 12 chars) — legacy single-password mode when ALLOW_LEGACY_ADMIN_PASSWORD=true
ADMIN_PASSWORD=

# Per-user admin accounts (recommended). Bootstrap with:
#   npx tsx scripts/create-admin-user.ts --email you@company.com --password "..." --role SUPER_ADMIN
# Roles: SUPER_ADMIN | COMPANY_ADMIN | REVIEWER | ANALYST
# COMPANY_ADMIN requires --company-id <uuid>

# Session signing (min 32 chars — openssl rand -hex 32)
SESSION_SECRET=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=aura-uploads

# Optional
PLATFORM_NAME=AURA-METNMAT

# Employee mobile OTP (MSG91 — +91 SMS)
# 1. MSG91 dashboard → OTP → Templates → copy Template ID (DLT-approved, use ##OTP## variable)
# 2. MSG91 dashboard → API → copy Auth Key
# Local dev without MSG91: OTP_PROVIDER=dev (logs OTP to console)
OTP_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
OTP_SECRET_PEPPER=
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
# Optional: logs OTP in server console when MSG91 fails (local dev uses this automatically)
# OTP_SMS_DEV_FALLBACK=true

# Optional — admin credential delivery via SMS (separate from interview OTP)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Local only: folder for Excel/PDF import via admin
# IMPORT_DATA_DIR=
