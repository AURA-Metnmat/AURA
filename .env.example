# AURA-METNMAT — Supabase + Vercel (copy values into Vercel Environment Variables)

# Supabase Postgres — replace [YOUR-PASSWORD] with Database password (Settings → Database)
# Transaction pooler (port 6543) — app runtime
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler (port 5432) — Prisma db push / migrations
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# OpenAI
OPENAI_API_KEY=

# Public app URL — use your Vercel production domain
NEXT_PUBLIC_APP_URL=https://aura-blond-one.vercel.app

# Admin login (min 12 chars)
ADMIN_PASSWORD=

# Session signing (min 32 chars — openssl rand -hex 32)
SESSION_SECRET=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=aura-uploads

# Optional
PLATFORM_NAME=AURA-METNMAT

# Local only: folder for Excel/PDF import via admin
# IMPORT_DATA_DIR=
